function Library:ToggleKey(key)
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed and input.KeyCode == key then
            self.ScreenGui.Enabled = not self.ScreenGui.Enabled
        end
    end)
end

