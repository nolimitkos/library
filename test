function Library:AddToggle(parent, text, default, callback)
    local toggleFrame = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundTransparency = 1,
        Parent = parent
    })

    local label = Create("TextLabel", {
        Size = UDim2.new(1, -60, 1, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Color3.fromRGB(180, 180, 190),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = toggleFrame
    })

    local toggleBtn = Create("TextButton", {
        Size = UDim2.new(0, 44, 0, 22),
        Position = UDim2.new(1, -48, 0.5, -11),
        BackgroundColor3 = Color3.fromRGB(35, 35, 42),
        BorderSizePixel = 0,
        Text = "",
        Parent = toggleFrame
    })
    RoundCorners(toggleBtn, 11)

    local circle = Create("Frame", {
        Size = UDim2.new(0, 18, 0, 18),
        Position = UDim2.new(0, 2, 0.5, -9),
        BackgroundColor3 = Color3.fromRGB(160, 160, 170),
        BorderSizePixel = 0,
        Parent = toggleBtn
    })
    RoundCorners(circle, 9)

    local enabled = default or false

    local function updateToggle()
        if enabled then
            Tween(toggleBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(80, 120, 200)})
            Tween(circle, TweenInfo.new(0.2), {Position = UDim2.new(0, 24, 0.5, -9), BackgroundColor3 = Color3.fromRGB(220, 220, 240)})
        else
            Tween(toggleBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(35, 35, 42)})
            Tween(circle, TweenInfo.new(0.2), {Position = UDim2.new(0, 2, 0.5, -9), BackgroundColor3 = Color3.fromRGB(160, 160, 170)})
        end
        if callback then callback(enabled) end
    end

    if enabled then updateToggle() end

    toggleBtn.MouseButton1Click:Connect(function()
        enabled = not enabled
        updateToggle()
    end)

    return {
        Set = function(val)
            enabled = val
            updateToggle()
        end,
        Get = function() return enabled end
    }
end

function Library:AddSlider(parent, text, min, max, default, callback)
    local sliderFrame = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundTransparency = 1,
        Parent = parent
    })

    local label = Create("TextLabel", {
        Size = UDim2.new(0.5, 0, 0, 20),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Color3.fromRGB(180, 180, 190),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = sliderFrame
    })

    local valueBox = Create("TextBox", {
        Size = UDim2.new(0, 50, 0, 20),
        Position = UDim2.new(1, -55, 0, 0),
        BackgroundColor3 = Color3.fromRGB(28, 28, 34),
        BorderSizePixel = 0,
        Text = tostring(default or min),
        TextColor3 = Color3.fromRGB(200, 200, 210),
        TextSize = 11,
        Font = Enum.Font.Gotham,
        Parent = sliderFrame
    })
    RoundCorners(valueBox, 4)
    AddStroke(valueBox, Color3.fromRGB(45, 45, 55), 1)

    local sliderBg = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 6),
        Position = UDim2.new(0, 0, 0, 32),
        BackgroundColor3 = Color3.fromRGB(30, 30, 38),
        BorderSizePixel = 0,
        Parent = sliderFrame
    })
    RoundCorners(sliderBg, 3)

    local sliderFill = Create("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = Color3.fromRGB(80, 120, 200),
        BorderSizePixel = 0,
        Parent = sliderBg
    })
    RoundCorners(sliderFill, 3)

    local sliderKnob = Create("Frame", {
        Size = UDim2.new(0, 14, 0, 14),
        Position = UDim2.new(0, -7, 0.5, -7),
        BackgroundColor3 = Color3.fromRGB(200, 200, 220),
        BorderSizePixel = 0,
        Parent = sliderFill
    })
    RoundCorners(sliderKnob, 7)

    local value = default or min
    local dragging = false

    local function updateSlider(inputX)
        local pos = math.clamp((inputX - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        value = math.floor(min + (max - min) * pos)
        sliderFill.Size = UDim2.new(pos, 0, 1, 0)
        valueBox.Text = tostring(value)
        if callback then callback(value) end
    end

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            updateSlider(input.Position.X)
        end
    end)

    sliderKnob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    valueBox.FocusLost:Connect(function()
        local num = tonumber(valueBox.Text)
        if num then
            value = math.clamp(num, min, max)
            local pos = (value - min) / (max - min)
            sliderFill.Size = UDim2.new(pos, 0, 1, 0)
            valueBox.Text = tostring(value)
            if callback then callback(value) end
        else
            valueBox.Text = tostring(value)
        end
    end)

    local initialPos = (value - min) / (max - min)
    sliderFill.Size = UDim2.new(initialPos, 0, 1, 0)

    return {
        Set = function(val)
            value = math.clamp(val, min, max)
            local pos = (value - min) / (max - min)
            sliderFill.Size = UDim2.new(pos, 0, 1, 0)
            valueBox.Text = tostring(value)
            if callback then callback(value) end
        end,
        Get = function() return value end
    }
end

function Library:AddButton(parent, text, callback)
    local btn = Create("TextButton", {
        Size = UDim2.new(1, 0, 0, 32),
        BackgroundColor3 = Color3.fromRGB(30, 30, 38),
        BorderSizePixel = 0,
        Text = text,
        TextColor3 = Color3.fromRGB(200, 200, 210),
        TextSize = 12,
        Font = Enum.Font.GothamSemibold,
        Parent = parent
    })
    RoundCorners(btn, 8)
    AddStroke(btn, Color3.fromRGB(50, 50, 60), 1)

    btn.MouseEnter:Connect(function()
        Tween(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(40, 40, 50)})
    end)

    btn.MouseLeave:Connect(function()
        Tween(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(30, 30, 38)})
    end)

    btn.MouseButton1Down:Connect(function()
        Tween(btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(50, 50, 65)})
    end)

    btn.MouseButton1Up:Connect(function()
        Tween(btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(40, 40, 50)})
    end)

    btn.MouseButton1Click:Connect(function()
        if callback then callback() end
    end)

    return btn
end

function Library:AddDropdown(parent, text, options, callback)
    local dropdownFrame = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundTransparency = 1,
        Parent = parent
    })

    local label = Create("TextLabel", {
        Size = UDim2.new(0.4, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Color3.fromRGB(180, 180, 190),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = dropdownFrame
    })

    local dropdownBtn = Create("TextButton", {
        Size = UDim2.new(0.55, 0, 0, 28),
        Position = UDim2.new(0.45, 0, 0.5, -14),
        BackgroundColor3 = Color3.fromRGB(28, 28, 34),
        BorderSizePixel = 0,
        Text = options[1] or "Select",
        TextColor3 = Color3.fromRGB(200, 200, 210),
        TextSize = 11,
        Font = Enum.Font.Gotham,
        Parent = dropdownFrame
    })
    RoundCorners(dropdownBtn, 6)
    AddStroke(dropdownBtn, Color3.fromRGB(45, 45, 55), 1)

    local arrow = Create("ImageLabel", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new(1, -20, 0.5, -6),
        BackgroundTransparency = 1,
        Image = "rbxassetid://3926307971",
        ImageRectOffset = Vector2.new(324, 524),
        ImageRectSize = Vector2.new(36, 36),
        ImageColor3 = Color3.fromRGB(140, 140, 150),
        Parent = dropdownBtn
    })

    local dropdownList = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, 30),
        BackgroundColor3 = Color3.fromRGB(24, 24, 30),
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Visible = false,
        ZIndex = 10,
        Parent = dropdownBtn
    })
    RoundCorners(dropdownList, 6)
    AddStroke(dropdownList, Color3.fromRGB(45, 45, 55), 1)

    local listLayout = Create("UIListLayout", {
        Padding = UDim.new(0, 2),
        Parent = dropdownList
    })

    local open = false

    for i, option in ipairs(options or {}) do
        local optionBtn = Create("TextButton", {
            Size = UDim2.new(1, 0, 0, 26),
            BackgroundColor3 = Color3.fromRGB(24, 24, 30),
            BorderSizePixel = 0,
            Text = option,
            TextColor3 = Color3.fromRGB(180, 180, 190),
            TextSize = 11,
            Font = Enum.Font.Gotham,
            ZIndex = 11,
            Parent = dropdownList
        })

        optionBtn.MouseEnter:Connect(function()
            Tween(optionBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(35, 35, 45)})
        end)

        optionBtn.MouseLeave:Connect(function()
            Tween(optionBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(24, 24, 30)})
        end)

        optionBtn.MouseButton1Click:Connect(function()
            dropdownBtn.Text = option
            open = false
            dropdownList.Visible = false
            Tween(arrow, TweenInfo.new(0.2), {Rotation = 0})
            if callback then callback(option) end
        end)
    end

    dropdownBtn.MouseButton1Click:Connect(function()
        open = not open
        if open then
            dropdownList.Visible = true
            local totalHeight = #options * 28 + 4
            dropdownList.Size = UDim2.new(1, 0, 0, math.min(totalHeight, 150))
            Tween(arrow, TweenInfo.new(0.2), {Rotation = 180})
        else
            dropdownList.Visible = false
            Tween(arrow, TweenInfo.new(0.2), {Rotation = 0})
        end
    end)

    return {
        Set = function(val)
            dropdownBtn.Text = val
            if callback then callback(val) end
        end,
        Get = function() return dropdownBtn.Text end
    }
end

function Library:AddInput(parent, text, placeholder, callback)
    local inputFrame = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundTransparency = 1,
        Parent = parent
    })

    local label = Create("TextLabel", {
        Size = UDim2.new(0.4, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Color3.fromRGB(180, 180, 190),
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = inputFrame
    })

    local inputBox = Create("TextBox", {
        Size = UDim2.new(0.55, 0, 0, 28),
        Position = UDim2.new(0.45, 0, 0.5, -14),
        BackgroundColor3 = Color3.fromRGB(28, 28, 34),
        BorderSizePixel = 0,
        Text = "",
        PlaceholderText = placeholder or "Enter...",
        PlaceholderColor3 = Color3.fromRGB(90, 90, 100),
        TextColor3 = Color3.fromRGB(200, 200, 210),
        TextSize = 11,
        Font = Enum.Font.Gotham,
        ClearTextOnFocus = false,
        Parent = inputFrame
    })
    RoundCorners(inputBox, 6)
    AddStroke(inputBox, Color3.fromRGB(45, 45, 55), 1)

    inputBox.FocusLost:Connect(function()
        if callback then callback(inputBox.Text) end
    end)

    return {
        Set = function(val) inputBox.Text = val end,
        Get = function() return inputBox.Text end
    }
end

