        BackgroundTransparency = 1,
        Image = iconId or "rbxassetid://3926305904",
        ImageColor3 = Color3.fromRGB(140, 140, 150),
        Parent = tabBtn
    })

    local tabLabel = Create("TextLabel", {
        Name = "Label",
        Size = UDim2.new(1, -45, 1, 0),
        Position = UDim2.new(0, 38, 0, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = Color3.fromRGB(160, 160, 170),
        TextSize = 13,
        Font = Enum.Font.GothamSemibold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = tabBtn
    })

    local tabPage = Create("ScrollingFrame", {
        Name = name .. "Page",
        Size = UDim2.new(1, -20, 1, -20),
        Position = UDim2.new(0, 10, 0, 10),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Color3.fromRGB(50, 50, 60),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        Visible = false,
        Parent = self.ContentFrame
    })

    local pageList = Create("UIListLayout", {
        Padding = UDim.new(0, 12),
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        Parent = tabPage
    })

    pageList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        tabPage.CanvasSize = UDim2.new(0, 0, 0, pageList.AbsoluteContentSize.Y + 20)
    end)

    local tabData = {
        Button = tabBtn,
        Page = tabPage,
        Name = name,
        Icon = tabIcon,
        Label = tabLabel
    }

    table.insert(self.Tabs, tabData)

    tabBtn.MouseButton1Click:Connect(function()
        self:SwitchTab(tabData)
    end)

    tabBtn.MouseEnter:Connect(function()
        if self.ActiveTab ~= tabData then
            Tween(tabBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(28, 28, 34)})
        end
    end)

    tabBtn.MouseLeave:Connect(function()
        if self.ActiveTab ~= tabData then
            Tween(tabBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(20, 20, 24)})
        end
    end)

    if #self.Tabs == 1 then
        self:SwitchTab(tabData)
    end

    return tabPage
end

function Library:SwitchTab(tabData)
    if self.ActiveTab == tabData then return end

    if self.ActiveTab then
        Tween(self.ActiveTab.Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(20, 20, 24)})
        self.ActiveTab.Icon.ImageColor3 = Color3.fromRGB(140, 140, 150)
        self.ActiveTab.Label.TextColor3 = Color3.fromRGB(160, 160, 170)
        self.ActiveTab.Page.Visible = false
    end

    self.ActiveTab = tabData
    Tween(tabData.Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(35, 35, 45)})
    tabData.Icon.ImageColor3 = Color3.fromRGB(180, 180, 200)
    tabData.Label.TextColor3 = Color3.fromRGB(220, 220, 230)
    tabData.Page.Visible = true

    local indicator = Create("Frame", {
        Size = UDim2.new(0, 3, 0, 20),
        Position = UDim2.new(0, 0, 0.5, -10),
        BackgroundColor3 = Color3.fromRGB(120, 120, 200),
        BorderSizePixel = 0,
        Parent = tabData.Button
    })
    RoundCorners(indicator, 2)

    task.delay(0.3, function()
        if tabData.Button:FindFirstChild(indicator.Name) then
            indicator:Destroy()
        end
    end)
end

